# Root .gitignore for Monorepo
# This prevents committing sensitive files and build artifacts

# === Node.js ===
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.node_repl_history

# === Environment Files (CRITICAL - NEVER COMMIT) ===
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# === Build Outputs ===
# dist/  # TEMPORARILY DISABLED for GitHub Pages deployment
build/
/backend/dist
/decentralizedenterpriseresourceplanning/dist

# === Development ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === TypeScript ===
*.tsbuildinfo
tsconfig*.tsbuildinfo

# === Testing ===
coverage/
.nyc_output/
jest.config.js

# === Logs ===
logs/
*.log
lerna-debug.log*

# === Temporary ===
.cache/
.temp/
temp/
tmp/
uploads/

# === IDEs ===
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.iml

# === OS ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# === Editor files ===
*~
*.swp
*.swo
.vscode/

# === Backend specific ===
backend/dist/
backend/coverage/
backend/.env*

# === Frontend specific ===
decentralizedenterpriseresourceplanning/dist/
decentralizedenterpriseresourceplanning/.env.local*

# === Docker ===
.docker/
docker-compose.override.yml

# === VS Code ===
.vscode/settings.json
.vscode/extensions.json

# === Package Manager ===
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
